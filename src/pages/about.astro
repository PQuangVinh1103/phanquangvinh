<!DOCTYPE html>
<html lang="vi" data-lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Về tôi — Phan Quang Vinh</title>
  <meta name="description" content="Blog và portfolio cá nhân của Phan Quang Vinh. Tài chính, đầu tư, AI automation và cuộc sống." />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />

  <style>
    /* =====================
       DESIGN TOKENS (tim.blog style - Neutral Navy & Slate)
     ===================== */
    :root {
      --color-primary: #002E4E; /* Deep Neutral Navy Blue */
      --color-secondary: #4A607A; /* Cool Slate Gray-Blue */
      --color-accent: #B38E50; /* Elegant Bronze/Gold */
      --color-bg-1: #FFFFFF; /* Pure White background */
      --color-bg-2: #F7F9FA; /* Neutral Ice Blue-Gray */
      --color-bg-3: #ECEFF1; /* Light Neutral Gray */
      --color-bg-4: #D9E1E8; /* Border Slate-Gray */
      --color-fg-1: #0A131A; /* Dark Navy Black */
      --color-fg-2: #1E2D38; /* Deep Charcoal Slate */
      --color-fg-3: #485966; /* Medium Slate */
      --color-fg-4: #738491; /* Light Slate */
      --color-nav-bg: #001C2F; /* Deep Navy Blue (tim.blog) */

      --font-base: "DM Sans", sans-serif;
      --font-serif: "Lora", Georgia, serif;
      --fw-light: 300;
      --fw-regular: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
      --fw-bold: 700;

      --lh-tiny: 1.1;
      --lh-small: 1.25;
      --lh-medium: 1.4;
      --lh-normal: 1.6;

      --fs-xs: clamp(0.875rem, 0.875rem + 0.1vw, 0.9375rem);
      --fs-sm: clamp(1rem, 1rem + 0.23vw, 1.125rem);
      --fs-base: clamp(1.125rem, 1.125rem + 0.23vw, 1.25rem);
      --fs-lg: clamp(1.25rem, 1.25rem + 1.36vw, 2rem);
      --fs-xl: clamp(1.5rem, 1.5rem + 2.05vw, 2.625rem);
      --fs-2xl: clamp(2rem, 2rem + 2.73vw, 3.5rem);
      --fs-3xl: clamp(2.5rem, 2.5rem + 3.6vw, 5rem);

      --sp-xs: clamp(0.5rem, 1vw, 1rem);
      --sp-sm: clamp(0.75rem, 1.5vw, 1.5rem);
      --sp-md: clamp(1rem, 2.5vw, 2rem);
      --sp-lg: clamp(1.5rem, 4vw, 3rem);
      --sp-xl: clamp(1.5rem, 6.5vw, 4rem);
      --sp-2xl: clamp(2rem, 7.5vw, 6rem);
      --sp-3xl: clamp(2rem, 8vw, 7.5rem);

      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --radius-pill: 100px;

      --max-w: 1200px;
      --max-w-text: 720px;

      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
      --shadow-md: 0 4px 18px rgba(0, 0, 0, 0.1);
      --shadow-lg: 0 16px 50px rgba(0, 0, 0, 0.15);

      --transition: 0.2s ease;
    }

    /* =====================
       RESET & BASE
    ===================== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-base);
      font-size: var(--fs-sm);
      font-weight: var(--fw-medium);
      line-height: var(--lh-normal);
      color: var(--color-fg-1);
      background-color: var(--color-bg-2);
    }

    img { max-width: 100%; height: auto; display: block; }

    a {
      color: var(--color-primary);
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color var(--transition);
    }
    a:hover { color: var(--color-fg-1); text-decoration: none; }

    h1, h2, h3 {
      font-family: var(--font-serif);
      font-weight: var(--fw-bold);
      letter-spacing: -0.01em;
      line-height: var(--lh-tiny);
      color: var(--color-fg-1);
    }
    h4, h5, h6 {
      font-family: var(--font-base);
      font-weight: var(--fw-semibold);
      letter-spacing: -0.02em;
      line-height: var(--lh-tiny);
      color: var(--color-fg-1);
    }
    h1 { font-size: var(--fs-2xl); }
    h2 { font-size: var(--fs-xl); font-weight: var(--fw-bold); }
    h3 { font-size: var(--fs-lg); }
    h4 { font-size: var(--fs-base); }
    h5 { font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: 0.05em; }

    ul { list-style: none; }

    /* =====================
       LAYOUT UTILITIES
    ===================== */
    .container {
      width: 100%;
      max-width: var(--max-w);
      margin-inline: auto;
      padding-inline: var(--sp-md);
    }
    .container--text { max-width: var(--max-w-text); }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
      padding: 0.625em var(--sp-sm);
      border-radius: var(--radius-pill);
      font-family: var(--font-base);
      font-size: var(--fs-sm);
      font-weight: var(--fw-medium);
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background-color var(--transition), color var(--transition);
    }
    .btn--primary {
      background-color: var(--color-primary);
      color: #fff;
    }
    .btn--primary:hover { background-color: var(--color-fg-1); color: #fff; }

    .btn--outline {
      background-color: transparent;
      color: #fff;
      border: 1.5px solid rgba(255, 255, 255, 0.4);
    }
    .btn--outline:hover { background-color: rgba(255,255,255,0.15); color: #fff; }

    .btn--accent {
      background-color: var(--color-accent);
      color: var(--color-fg-1);
    }
    .btn--accent:hover { background-color: #e5b330; color: var(--color-fg-1); }

    .tag {
      display: inline-block;
      padding: 0.25em 0.75em;
      border-radius: var(--radius-pill);
      font-size: var(--fs-xs);
      font-weight: var(--fw-semibold);
      background-color: var(--color-bg-3);
      color: var(--color-fg-2);
      text-decoration: none;
    }
    .tag:hover { background-color: var(--color-bg-4); color: var(--color-fg-1); }
    .tag--accent { background-color: #f5ece2; color: #785135; }
    .tag--blue { background-color: #e2ede5; color: #2e4c38; }

    /* i18n: hide/show by lang */
    [data-vi], [data-en] { }
    html[data-lang="vi"] [data-en] { display: none; }
    html[data-lang="en"] [data-vi] { display: none; }

    /* =====================
       HEADER / NAV
     ===================== */
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 1000;
      background: var(--color-nav-bg);
      transition: box-shadow var(--transition);
    }
    .site-header.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.3); }

    .navbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-block: var(--sp-sm);
      gap: var(--sp-md);
    }

    .nav-logo {
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .nav-logo__icon {
      height: 24px;
      width: auto;
      flex-shrink: 0;
      transition: transform var(--transition);
    }
    .nav-logo:hover .nav-logo__icon {
      transform: scale(1.08);
    }
    .nav-logo__text {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .nav-logo__name {
      font-size: 1.125rem;
      font-weight: var(--fw-bold);
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .nav-logo__sub {
      font-size: 0.75rem;
      font-weight: var(--fw-regular);
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.01em;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .nav-links a {
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      font-size: var(--fs-xs);
      font-weight: var(--fw-medium);
      padding: 0.4em 0.75em;
      border-radius: var(--radius-sm);
      transition: color var(--transition), background-color var(--transition);
    }
    .nav-links a:hover { color: #fff; background-color: rgba(255,255,255,0.1); }
    .nav-links a.active { color: #fff; background-color: rgba(255,255,255,0.15); font-weight: var(--fw-bold); }

    .lang-toggle {
      display: flex;
      align-items: center;
      background: rgba(255,255,255,0.1);
      border-radius: var(--radius-pill);
      padding: 2px;
      gap: 2px;
    }
    .lang-btn {
      border: none;
      background: transparent;
      color: rgba(255,255,255,0.6);
      font-family: var(--font-base);
      font-size: 0.75rem;
      font-weight: var(--fw-semibold);
      padding: 4px 10px;
      border-radius: var(--radius-pill);
      cursor: pointer;
      transition: all var(--transition);
    }
    .lang-btn.active {
      background: #fff;
      color: var(--color-fg-1);
    }
    .lang-btn:hover:not(.active) { color: #fff; }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }
    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
      transition: all 0.3s ease;
    }
    .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .mobile-menu {
      display: none;
      background: var(--color-nav-bg);
      padding: var(--sp-sm) var(--sp-md);
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .mobile-menu.open { display: block; }
    .mobile-menu a {
      display: block;
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      font-size: var(--fs-sm);
      font-weight: var(--fw-medium);
      padding: 0.75em 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .mobile-menu a:hover { color: #fff; }
    .mobile-menu a.active { color: #fff; background-color: rgba(255,255,255,0.1); font-weight: var(--fw-bold); }
    .mobile-menu a:last-child { border-bottom: none; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
    }

    /* =====================
       HERO
     ===================== */
    .hero {
      min-height: 100svh;
      background:
        linear-gradient(135deg, rgba(0, 28, 47, 0.95) 0%, rgba(0, 46, 78, 0.9) 70%, rgba(0, 28, 47, 0.98) 100%),
        linear-gradient(135deg, #001C2F 0%, #002E4E 50%, #001C2F 100%);
      display: flex;
      align-items: center;
      padding-top: 80px;
      position: relative;
      overflow: hidden;
    }

    /* decorative grid pattern */
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }

    .hero__inner {
      position: relative;
      z-index: 1;
      padding-block: var(--sp-3xl);
    }

    .hero__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
      color: var(--color-accent);
      font-size: var(--fs-xs);
      font-weight: var(--fw-semibold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: var(--sp-sm);
    }
    .hero__eyebrow::before {
      content: "";
      display: block;
      width: 24px;
      height: 2px;
      background: var(--color-accent);
      border-radius: 2px;
    }

    .hero__title {
      font-size: var(--fs-3xl);
      font-weight: var(--fw-bold);
      color: #fff;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: var(--sp-md);
      max-width: 16ch;
    }
    .hero__title .accent { color: var(--color-accent); }

    .hero__desc {
      font-size: var(--fs-base);
      color: rgba(255,255,255,0.72);
      line-height: var(--lh-medium);
      max-width: 52ch;
      margin-bottom: var(--sp-lg);
    }

    .hero__cta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: var(--sp-2xl);
    }

    .hero__stats {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-lg);
      padding-top: var(--sp-lg);
      border-top: 1px solid rgba(255,255,255,0.12);
    }
    .stat { display: flex; flex-direction: column; gap: 0.2em; }
    .stat__num {
      font-size: var(--fs-xl);
      font-weight: var(--fw-bold);
      color: #fff;
      line-height: 1;
    }
    .stat__num .unit {
      font-size: 0.55em;
      color: var(--color-accent);
      font-weight: var(--fw-semibold);
    }
    .stat__label {
      font-size: var(--fs-xs);
      color: rgba(255,255,255,0.5);
      font-weight: var(--fw-medium);
    }

    /* scroll indicator */
    .hero__scroll {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4em;
      color: rgba(255,255,255,0.4);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      animation: bounce 2s infinite;
    }
    .hero__scroll svg { opacity: 0.5; }

    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(6px); }
    }

    /* =====================
       SECTION COMMONS
    ===================== */
    section { padding-block: var(--sp-2xl); }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
      color: var(--color-primary);
      font-size: var(--fs-xs);
      font-weight: var(--fw-semibold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: var(--sp-xs);
    }
    .section-label::before {
      content: "";
      display: block;
      width: 20px;
      height: 2px;
      background: var(--color-primary);
      border-radius: 2px;
    }

    .section-title {
      font-size: var(--fs-xl);
      margin-bottom: var(--sp-sm);
      color: var(--color-fg-1);
    }

    .section-desc {
      font-size: var(--fs-base);
      color: var(--color-fg-3);
      max-width: 60ch;
      line-height: var(--lh-medium);
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: var(--sp-sm);
      margin-bottom: var(--sp-xl);
    }
    .section-header .link-all {
      font-size: var(--fs-xs);
      font-weight: var(--fw-semibold);
      white-space: nowrap;
    }

    /* =====================
       ABOUT SECTION
    ===================== */
    .about { background-color: var(--color-bg-1); }

    .about__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-2xl);
      align-items: center;
    }

    .about__avatar-wrap {
      position: relative;
    }
    .about__avatar {
      width: 100%;
      aspect-ratio: 4/5;
      border-radius: var(--radius-lg);
      background: linear-gradient(135deg, var(--color-bg-2) 0%, var(--color-bg-3) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      border: 1px solid var(--color-bg-4);
    }
    .about__avatar-placeholder {
      font-size: 1rem;
      font-family: var(--font-base);
      color: var(--color-fg-4);
      user-select: none;
    }
    .about__avatar-badge {
      position: absolute;
      bottom: -1rem;
      right: -1rem;
      background: var(--color-accent);
      color: #fff;
      padding: 0.75em 1.25em;
      border-radius: var(--radius-md);
      font-size: var(--fs-xs);
      font-weight: var(--fw-bold);
      box-shadow: var(--shadow-md);
      line-height: 1.3;
      text-align: center;
    }
    .about__avatar-badge strong { display: block; font-size: var(--fs-base); }

    .about__content { display: flex; flex-direction: column; gap: var(--sp-md); }

    .about__name {
      font-size: var(--fs-xl);
      font-weight: var(--fw-bold);
      margin-bottom: 0.25em;
    }
    .about__role {
      font-size: var(--fs-base);
      color: var(--color-primary);
      font-weight: var(--fw-medium);
    }

    .about__bio {
      color: var(--color-fg-2);
      line-height: var(--lh-medium);
    }
    .about__bio p + p { margin-top: 0.75em; }

    .about__dna {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .dna-item {
      display: flex;
      align-items: center;
      gap: 0.6em;
      padding: 0.85em var(--sp-sm);
      border-radius: var(--radius-sm);
      background: var(--color-bg-2);
      border-left: 3px solid var(--color-primary);
    }
    .dna-item__text {
      font-size: var(--fs-xs);
      font-weight: var(--fw-semibold);
      color: var(--color-fg-1);
      line-height: 1.4;
    }

    @media (max-width: 768px) {
      .about__grid {
        grid-template-columns: 1fr;
        gap: var(--sp-xl);
      }
      .about__avatar-wrap {
        max-width: 320px;
        margin-inline: auto;
      }
      .about__avatar {
        aspect-ratio: 4/5;
      }
      .about__avatar-badge {
        bottom: -0.75rem;
        right: -0.75rem;
      }
      .about__dna {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 480px) {
      .about__dna { grid-template-columns: 1fr; }
    }

    /* =====================
       SKILLS / COMPETENCIES
    ===================== */
    .skills { background-color: var(--color-bg-2); }

    .skills__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--sp-sm);
    }

    .skill-card {
      background: var(--color-bg-1);
      border-radius: var(--radius-md);
      padding: var(--sp-md);
      box-shadow: none;
      transition: border-color var(--transition), background-color var(--transition);
      border: 1px solid var(--color-bg-4);
    }
    .skill-card:hover {
      border-color: var(--color-accent);
      background-color: var(--color-bg-1);
    }
    .skill-card__title {
      font-size: var(--fs-sm);
      font-weight: var(--fw-bold);
      font-family: var(--font-serif);
      color: var(--color-fg-1);
      margin-bottom: 0.5em;
    }
    .skill-card__desc {
      font-size: var(--fs-xs);
      color: var(--color-fg-3);
      line-height: var(--lh-medium);
    }
    .skill-card__tags {
      margin-top: 0.75rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    @media (max-width: 900px) { .skills__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .skills__grid { grid-template-columns: 1fr; } }

    /* =====================
       FEATURED PROJECTS
    ===================== */
    .projects { background-color: var(--color-bg-1); }

    .projects__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-sm);
    }

    .project-card {
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-bg-2);
      border: 1px solid var(--color-bg-4);
      transition: border-color var(--transition), box-shadow var(--transition);
      display: flex;
      flex-direction: column;
    }
    .project-card:hover {
      border-color: var(--color-accent);
    }
    .project-card__thumb {
      aspect-ratio: 16/9;
      background: linear-gradient(135deg, var(--thumb-from, var(--color-bg-3)) 0%, var(--thumb-to, var(--color-bg-4)) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-family: var(--font-base);
      color: var(--color-fg-3);
      border-bottom: 1px solid var(--color-bg-4);
    }
    .project-card__body {
      padding: var(--sp-md);
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .project-card__tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .project-card__title {
      font-family: var(--font-serif);
      font-size: var(--fs-base);
      font-weight: var(--fw-bold);
      color: var(--color-fg-1);
      line-height: var(--lh-small);
      text-decoration: none;
    }
    .project-card__title:hover { color: var(--color-primary); }
    .project-card__desc {
      font-size: var(--fs-xs);
      color: var(--color-fg-3);
      line-height: var(--lh-medium);
