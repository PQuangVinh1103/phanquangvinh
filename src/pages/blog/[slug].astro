---
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => post.data.status === 'published');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdoc)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(post.data.publishedAt);
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} - Phan Quang Vinh</title>
  <meta name="description" content={post.data.excerpt} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root { --nav:#001c2f; --primary:#002e4e; --accent:#b38e50; --bg:#f7f9fa; --surface:#fff; --text:#0a131a; --muted:#485966; --line:#d9e1e8; --font-base:"DM Sans",sans-serif; --font-serif:"Lora",Georgia,serif; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-base); color: var(--text); background: var(--bg); line-height: 1.7; }
    img { display: block; max-width: 100%; }
    .site-header { background: var(--nav); color: #fff; }
    .nav { max-width: 940px; margin: 0 auto; padding: 18px 24px; display: flex; justify-content: space-between; gap: 20px; }
    .nav a { color: rgba(255,255,255,.86); text-decoration: none; }
    .nav a:hover { color: #fff; }
    main { max-width: 820px; margin: 0 auto; padding: 64px 24px 84px; }
    .back { color: var(--primary); font-weight: 700; text-decoration: none; }
    .meta { margin-top: 28px; color: var(--accent); font-size: 14px; font-weight: 700; text-transform: uppercase; }
    h1 { margin-top: 12px; font: 700 clamp(2.2rem, 6vw, 4.5rem)/1.05 var(--font-serif); }
    .excerpt { margin-top: 18px; color: var(--muted); font-size: 20px; }
    .cover { margin-top: 34px; overflow: hidden; border-radius: 8px; border: 1px solid var(--line); background: var(--surface); }
    .cover img { width: 100%; max-height: 460px; object-fit: cover; }
    .content { margin-top: 44px; padding: 34px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); }
    .content :global(h2), .content :global(h3) { margin: 1.6em 0 .6em; font-family: var(--font-serif); line-height: 1.2; }
    .content :global(p), .content :global(ul), .content :global(ol), .content :global(blockquote) { margin-top: 1em; }
    .content :global(a) { color: var(--primary); }
    .content :global(ul), .content :global(ol) { padding-left: 1.4rem; }
    .content :global(blockquote) { border-left: 3px solid var(--accent); padding-left: 1rem; color: var(--muted); }
    @media (max-width: 620px) { main { padding-top: 42px; } .nav { flex-direction: column; } .content { padding: 24px; } }
  </style>
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Main navigation">
      <a href="/">Phan Quang Vinh</a>
      <a href="/blog">Blog</a>
    </nav>
  </header>

  <main>
    <a class="back" href="/blog">← Tất cả bài viết</a>
    <div class="meta">{formattedDate} · {post.data.readingTime || '5 phút đọc'}</div>
    <h1>{post.data.title}</h1>
    <p class="excerpt">{post.data.excerpt}</p>
    {post.data.coverImage && (
      <figure class="cover">
        <img src={post.data.coverImage} alt="" />
      </figure>
    )}
    <article class="content">
      <Content />
    </article>
  </main>
</body>
</html>
