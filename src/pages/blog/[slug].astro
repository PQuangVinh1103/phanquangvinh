---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => post.data.status === 'published');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdoc)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(post.data.publishedAt);
---
<BaseLayout title={`${post.data.title} - Phan Quang Vinh`} description={post.data.excerpt} activeNav="blog">
  <style slot="head">
    main { max-width: 820px; margin: 0 auto; padding: 56px 24px 80px; }
    .back { color: var(--primary); font-weight: 700; text-decoration: none; font-size: 0.9rem; }
    .back:hover { text-decoration: underline; }
    .meta { margin-top: 28px; color: var(--accent); font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
    h1 { margin-top: 10px; font: 700 clamp(2rem, 5.5vw, 4rem)/1.05 var(--font-serif); color: var(--text); }
    .excerpt { margin-top: 16px; color: var(--muted); font-size: 1.2rem; line-height: 1.5; }
    .cover { margin-top: 32px; overflow: hidden; border-radius: 10px; border: 1px solid var(--line); background: var(--surface); }
    .cover img { width: 100%; max-height: 460px; object-fit: cover; }
    .content { margin-top: 40px; padding: 36px; border: 1px solid var(--line); border-radius: 10px; background: var(--surface); line-height: 1.75; }
    .content :global(h2), .content :global(h3) { margin: 1.8em 0 .6em; font-family: var(--font-serif); line-height: 1.2; color: var(--text); }
    .content :global(h2) { font-size: clamp(1.4rem, 3vw, 1.9rem); }
    .content :global(h3) { font-size: clamp(1.1rem, 2.5vw, 1.4rem); }
    .content :global(p), .content :global(ul), .content :global(ol), .content :global(blockquote) { margin-top: 1em; color: var(--text); }
    .content :global(a) { color: var(--primary); }
    .content :global(ul), .content :global(ol) { padding-left: 1.5rem; }
    .content :global(li) { margin-top: .4em; }
    .content :global(blockquote) { border-left: 3px solid var(--accent); padding-left: 1.25rem; color: var(--muted); font-style: italic; }
    .content :global(code) { background: var(--bg); padding: .15em .4em; border-radius: 4px; font-size: .875em; }
    .content :global(pre) { background: #0a131a; color: #e2e8f0; padding: 1.25rem; border-radius: 8px; overflow-x: auto; margin-top: 1em; }
    .content :global(pre code) { background: none; padding: 0; }
    .content :global(img) { border-radius: 8px; margin-top: 1em; }
    @media (max-width: 620px) { main { padding-top: 36px; } .content { padding: 22px; } }
  </style>

  <main>
    <a class="back" href="/blog">← Tất cả bài viết</a>
    <div class="meta">{formattedDate} · {post.data.readingTime || '5 phút đọc'}</div>
    <h1>{post.data.title}</h1>
    <p class="excerpt">{post.data.excerpt}</p>
    {post.data.coverImage && (
      <figure class="cover">
        <img src={post.data.coverImage} alt="" />
      </figure>
    )}
    <article class="content">
      <Content />
    </article>
  </main>
</BaseLayout>
