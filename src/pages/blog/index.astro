---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const categoryLabels = {
  finance: 'Tài chính',
  ai: 'AI & Automation',
  productivity: 'Năng suất',
  life: 'Cuộc sống',
};

const getPostSlug = (id) => id.replace(/\.(md|mdoc)$/, '');
const formatDate = (date) =>
  new Intl.DateTimeFormat('vi-VN', { month: 'long', year: 'numeric' }).format(date);

const posts = (await getCollection('posts'))
  .filter((post) => post.data.status === 'published')
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<BaseLayout
  title="Blog - Phan Quang Vinh"
  description="Các bài viết của Phan Quang Vinh về tài chính, AI automation, năng suất và cuộc sống."
  activeNav="blog"
>
  <style slot="head">
    .wrap { max-width: 1120px; margin: 0 auto; padding: 64px 24px 80px; }
    .eyebrow { color: var(--primary); font-size: 13px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
    h1 { margin-top: 10px; max-width: 760px; font: 700 clamp(2.2rem, 5vw, 4rem)/1.05 var(--font-serif); color: var(--text); }
    .lead { margin-top: 16px; max-width: 660px; color: var(--muted); font-size: 1.1rem; line-height: 1.6; }
    .filters { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 10px; }
    .filter { border: 1px solid var(--line); border-radius: 999px; background: var(--surface); padding: 7px 16px; color: var(--muted); font: inherit; font-size: 0.875rem; cursor: pointer; transition: all .15s; }
    .filter.active { background: var(--primary); border-color: var(--primary); color: #fff; }
    .filter:hover:not(.active) { border-color: var(--primary); color: var(--primary); }
    .grid { margin-top: 32px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px; }
    .post-card { display: flex; flex-direction: column; overflow: hidden; border: 1px solid var(--line); border-radius: 10px; background: var(--surface); text-decoration: none; box-shadow: 0 2px 8px rgba(0,0,0,.04); transition: border-color .15s, box-shadow .15s; }
    .post-card:hover { border-color: var(--primary); box-shadow: 0 4px 18px rgba(0,0,0,.09); }
    .thumb { aspect-ratio: 16/10; background: linear-gradient(135deg, #2a352e, #1b241e); overflow: hidden; }
    .thumb img { width: 100%; height: 100%; object-fit: cover; }
    .thumb-placeholder { width: 100%; height: 100%; display: grid; place-items: center; color: rgba(255,255,255,.6); font-weight: 600; font-size: 0.875rem; }
    .body { padding: 20px; display: flex; flex: 1; flex-direction: column; gap: 6px; }
    .cat { color: var(--accent); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
    .title { font: 700 1.2rem/1.25 var(--font-serif); color: var(--text); }
    .excerpt { color: var(--muted); font-size: 0.9rem; line-height: 1.55; flex: 1; }
    .meta { margin-top: auto; padding-top: 14px; color: #738491; font-size: 0.8rem; display: flex; gap: 8px; align-items: center; }
    .dot { width: 3px; height: 3px; background: currentColor; border-radius: 50%; }
    .empty { margin-top: 32px; padding: 28px; border: 1px dashed var(--line); border-radius: 8px; background: var(--surface); color: var(--muted); }
    @media (max-width: 860px) { .grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 580px) { .grid { grid-template-columns: 1fr; } .wrap { padding-top: 44px; } }
  </style>

  <main class="wrap">
    <p class="eyebrow">Bài viết mới nhất</p>
    <h1>Từ góc nhìn của tôi</h1>
    <p class="lead">Tài chính, AI automation, năng suất và những ghi chú thực tế trong quá trình học, làm và xây dựng hệ thống cá nhân.</p>

    <div class="filters" role="group" aria-label="Bộ lọc bài viết">
      <button class="filter active" data-category="all">Tất cả</button>
      <button class="filter" data-category="finance">Tài chính</button>
      <button class="filter" data-category="ai">AI & Automation</button>
      <button class="filter" data-category="productivity">Năng suất</button>
      <button class="filter" data-category="life">Cuộc sống</button>
    </div>

    {posts.length > 0 ? (
      <section class="grid" aria-label="Danh sách bài viết">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${getPostSlug(post.id)}`} data-cat-type={post.data.category}>
            <div class="thumb">
              {post.data.coverImage
                ? <img src={post.data.coverImage} alt="" />
                : <div class="thumb-placeholder">{categoryLabels[post.data.category]}</div>
              }
            </div>
            <div class="body">
              <span class="cat">{categoryLabels[post.data.category]}</span>
              <h2 class="title">{post.data.title}</h2>
              <p class="excerpt">{post.data.excerpt}</p>
              <div class="meta">
                <span>{post.data.readingTime || '5 phút đọc'}</span>
                <span class="dot" aria-hidden="true"></span>
                <span>{formatDate(post.data.publishedAt)}</span>
              </div>
            </div>
          </a>
        ))}
      </section>
    ) : (
      <div class="empty">Chưa có bài published. <a href="/keystatic">Mở Keystatic để tạo bài viết →</a></div>
    )}
  </main>

  <script>
    const filterBtns = document.querySelectorAll('.filter');
    const cards = document.querySelectorAll('.post-card');
    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.category;
        cards.forEach((card) => {
          card.style.display = cat === 'all' || card.dataset.catType === cat ? 'flex' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
