---
import { getCollection } from 'astro:content';

const categoryLabels = {
  finance: 'Tài chính',
  ai: 'AI & Automation',
  productivity: 'Năng suất',
  life: 'Cuộc sống',
};

const getPostSlug = (id) => id.replace(/\.(md|mdoc)$/, '');
const formatDate = (date) =>
  new Intl.DateTimeFormat('vi-VN', { month: 'long', year: 'numeric' }).format(date);

const posts = (await getCollection('posts'))
  .filter((post) => post.data.status === 'published')
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog - Phan Quang Vinh</title>
  <meta name="description" content="Các bài viết của Phan Quang Vinh về tài chính, AI automation, năng suất và cuộc sống." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --nav: #001c2f;
      --primary: #002e4e;
      --accent: #b38e50;
      --bg: #f7f9fa;
      --surface: #fff;
      --text: #0a131a;
      --muted: #485966;
      --line: #d9e1e8;
      --font-base: "DM Sans", sans-serif;
      --font-serif: "Lora", Georgia, serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-base); color: var(--text); background: var(--bg); line-height: 1.6; }
    a { color: inherit; }
    img { display: block; max-width: 100%; }
    .site-header { position: sticky; top: 0; z-index: 10; background: var(--nav); color: #fff; }
    .nav { max-width: 1120px; margin: 0 auto; padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; gap: 20px; }
    .brand { text-decoration: none; font-weight: 700; letter-spacing: .01em; }
    .nav-links { display: flex; gap: 20px; list-style: none; font-size: 15px; }
    .nav-links a { color: rgba(255,255,255,.82); text-decoration: none; }
    .nav-links a:hover, .nav-links .active { color: #fff; }
    .wrap { max-width: 1120px; margin: 0 auto; padding: 72px 24px; }
    .eyebrow { color: var(--primary); font-size: 13px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
    h1 { margin-top: 12px; max-width: 760px; font: 700 clamp(2.4rem, 6vw, 4.5rem)/1.05 var(--font-serif); }
    .lead { margin-top: 18px; max-width: 660px; color: var(--muted); font-size: 19px; }
    .filters { margin-top: 36px; display: flex; flex-wrap: wrap; gap: 10px; }
    .filter { border: 1px solid var(--line); border-radius: 999px; background: var(--surface); padding: 8px 14px; color: var(--muted); font: inherit; cursor: pointer; }
    .filter.active { background: var(--primary); border-color: var(--primary); color: #fff; }
    .grid { margin-top: 34px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px; }
    .post-card { display: flex; flex-direction: column; min-height: 100%; overflow: hidden; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); text-decoration: none; box-shadow: 0 2px 10px rgba(0,0,0,.04); }
    .thumb { aspect-ratio: 16 / 10; background: linear-gradient(135deg, #2a352e, #1b241e); color: rgba(255,255,255,.8); display: grid; place-items: center; font-weight: 600; }
    .thumb img { width: 100%; height: 100%; object-fit: cover; }
    .body { padding: 20px; display: flex; flex: 1; flex-direction: column; }
    .cat { color: var(--accent); font-size: 13px; font-weight: 700; text-transform: uppercase; }
    .title { margin-top: 8px; font: 700 22px/1.2 var(--font-serif); }
    .excerpt { margin-top: 10px; color: var(--muted); }
    .meta { margin-top: auto; padding-top: 18px; color: #738491; font-size: 14px; display: flex; gap: 10px; align-items: center; }
    .empty { margin-top: 34px; padding: 28px; border: 1px dashed var(--line); border-radius: 8px; background: var(--surface); color: var(--muted); }
    footer { border-top: 1px solid var(--line); background: var(--surface); }
    footer .wrap { padding-block: 26px; color: var(--muted); font-size: 14px; }
    @media (max-width: 860px) { .grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 620px) { .nav { align-items: flex-start; flex-direction: column; } .grid { grid-template-columns: 1fr; } .wrap { padding-block: 46px; } }
  </style>
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Main navigation">
      <a class="brand" href="/">Phan Quang Vinh</a>
      <ul class="nav-links">
        <li><a href="/">Trang chủ</a></li>
        <li><a href="/about">Giới thiệu</a></li>
        <li><a href="/projects">Dự án</a></li>
        <li><a class="active" href="/blog">Blog</a></li>
      </ul>
    </nav>
  </header>

  <main class="wrap">
    <p class="eyebrow">Bài viết mới nhất</p>
    <h1>Từ góc nhìn của tôi</h1>
    <p class="lead">Tài chính, AI automation, năng suất và những ghi chú thực tế trong quá trình học, làm và xây dựng hệ thống cá nhân.</p>

    <div class="filters" role="group" aria-label="Bộ lọc bài viết">
      <button class="filter active" data-category="all">Tất cả</button>
      <button class="filter" data-category="finance">Tài chính</button>
      <button class="filter" data-category="ai">AI & Automation</button>
      <button class="filter" data-category="productivity">Năng suất</button>
      <button class="filter" data-category="life">Cuộc sống</button>
    </div>

    {posts.length > 0 ? (
      <section class="grid" aria-label="Danh sách bài viết">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${getPostSlug(post.id)}`} data-cat-type={post.data.category}>
            <div class="thumb">
              {post.data.coverImage ? <img src={post.data.coverImage} alt="" /> : 'Blog'}
            </div>
            <div class="body">
              <span class="cat">{categoryLabels[post.data.category]}</span>
              <h2 class="title">{post.data.title}</h2>
              <p class="excerpt">{post.data.excerpt}</p>
              <div class="meta">
                <span>{post.data.readingTime || '5 phút đọc'}</span>
                <span aria-hidden="true">·</span>
                <span>{formatDate(post.data.publishedAt)}</span>
              </div>
            </div>
          </a>
        ))}
      </section>
    ) : (
      <div class="empty">Chưa có bài published. Mở /keystatic để tạo hoặc publish bài viết đầu tiên.</div>
    )}
  </main>

  <footer>
    <div class="wrap">© 2026 Phan Quang Vinh. Tất cả quyền được bảo lưu.</div>
  </footer>

  <script>
    const filterBtns = document.querySelectorAll('.filter');
    const cards = document.querySelectorAll('.post-card');

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((item) => item.classList.remove('active'));
        btn.classList.add('active');
        const category = btn.dataset.category;

        cards.forEach((card) => {
          card.style.display = category === 'all' || card.dataset.catType === category ? 'flex' : 'none';
        });
      });
    });
  </script>
</body>
</html>
