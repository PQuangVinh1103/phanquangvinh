    .post-card__title {
      font-family: var(--font-serif);
      font-size: var(--fs-base);
      font-weight: var(--fw-bold);
      color: var(--color-fg-1);
      line-height: var(--lh-small);
      text-decoration: none;
    }
    .post-card--sm .post-card__title { font-size: var(--fs-sm); }
    .post-card__title:hover { color: var(--color-primary); }
    .post-card__excerpt {
      font-size: var(--fs-xs);
      color: var(--color-fg-3);
      line-height: var(--lh-medium);
      flex: 1;
    }
    .post-card__meta {
      font-size: 0.7rem;
      color: var(--color-fg-4);
      display: flex;
      align-items: center;
      gap: 0.5em;
      margin-top: auto;
      padding-top: 0.5rem;
    }
    .post-card__meta-dot { width: 3px; height: 3px; background: currentColor; border-radius: 50%; }

    @media (max-width: 900px) { .blog__grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 580px) { .blog__grid { grid-template-columns: 1fr; } }

    /* =====================
       NEWSLETTER / CTA
    ===================== */
    .newsletter {
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-nav-bg) 100%);
      text-align: center;
    }
    .newsletter__inner { max-width: 600px; margin-inline: auto; }
    .newsletter h2 { color: #fff; margin-bottom: var(--sp-sm); }
    .newsletter p { color: rgba(255,255,255,0.75); margin-bottom: var(--sp-md); }
    .newsletter__form {
      display: flex;
      gap: 0.5rem;
      max-width: 440px;
      margin-inline: auto;
    }
    .newsletter__input {
      flex: 1;
      padding: 0.7em var(--sp-sm);
      border-radius: var(--radius-pill);
      border: none;
      font-family: var(--font-base);
      font-size: var(--fs-sm);
      outline: none;
    }
    .newsletter__input:focus { box-shadow: 0 0 0 3px rgba(255,255,255,0.3); }

    @media (max-width: 480px) {
      .newsletter__form { flex-direction: column; }
    }

    /* =====================
       FOOTER
    ===================== */
    .site-footer {
      background: var(--color-fg-1);
      color: rgba(255,255,255,0.5);
      padding-block: var(--sp-xl);
    }

    .footer__grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--sp-xl);
      padding-bottom: var(--sp-xl);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      margin-bottom: var(--sp-lg);
    }

    .footer__brand-name {
      font-size: var(--fs-base);
      font-weight: var(--fw-bold);
      color: #fff;
      margin-bottom: 0.5em;
    }
    .footer__brand-desc {
      font-size: var(--fs-xs);
      line-height: var(--lh-medium);
      margin-bottom: var(--sp-sm);
    }

    .footer__socials-text {
      font-size: var(--fs-xs);
      color: rgba(255,255,255,0.4);
      margin-top: var(--sp-sm);
    }
    .footer-social-link {
      color: rgba(255,255,255,0.6) !important;
      text-decoration: none !important;
      font-weight: var(--fw-semibold);
      transition: color var(--transition);
    }
    .footer-social-link:hover {
      color: #fff !important;
      text-decoration: underline !important;
    }

    .footer__col-title {
      font-size: var(--fs-xs);
      font-weight: var(--fw-semibold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.4);
      margin-bottom: var(--sp-sm);
    }
    .footer__links { display: flex; flex-direction: column; gap: 0.5rem; }
    .footer__links a {
      font-size: var(--fs-xs);
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      transition: color var(--transition);
    }
    .footer__links a:hover { color: #fff; }

    .footer__bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: var(--fs-xs);
    }
    .footer__bottom a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .footer__bottom a:hover { color: #fff; }

    @media (max-width: 900px) { .footer__grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 480px) {
      .footer__grid { grid-template-columns: 1fr; }
      .footer__bottom { flex-direction: column; text-align: center; }
    }

    /* =====================
       SCROLL ANIMATIONS
    ===================== */
    .fade-up {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .fade-up.visible { opacity: 1; transform: none; }
  </style>
</head>

