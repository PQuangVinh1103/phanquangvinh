    .project-card__desc {
      font-size: var(--fs-xs);
      color: var(--color-fg-3);
      line-height: var(--lh-medium);
      flex: 1;
    }
    .project-card__meta {
      display: flex;
      align-items: center;
      gap: 0.5em;
      font-size: var(--fs-xs);
      color: var(--color-fg-3);
      margin-top: auto;
      padding-top: 0.75rem;
      border-top: 1px solid var(--color-bg-4);
