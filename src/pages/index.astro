    .blog .section-title { color: var(--color-fg-1); }
    .blog .link-all { color: var(--color-primary) !important; }

    .blog__grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--sp-sm);
    }

    .post-card {
      background: var(--color-bg-2);
      border: 1px solid var(--color-bg-4);
      border-radius: var(--radius-md);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .post-card:hover {
      border-color: var(--color-primary);
      box-shadow: var(--shadow-sm);
    }
    .post-card--featured .post-card__body { padding: var(--sp-md); }
    .post-card__thumb {
      aspect-ratio: 16/9;
      background: linear-gradient(135deg, var(--thumb-from, var(--color-bg-3)) 0%, var(--thumb-to, var(--color-bg-4)) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-family: var(--font-base);
      color: var(--color-fg-3);
      border-bottom: 1px solid var(--color-bg-4);
    }
    .post-card__body {
      padding: var(--sp-sm);
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .post-card__cat {
      font-size: 0.7rem;
      font-weight: var(--fw-bold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-primary);
