                ? <img src={post.data.coverImage} alt="" style="width:100%;height:100%;object-fit:cover;" />
                : <span>{categoryLabelsVi[post.data.category]}</span>
              }
            </div>
            <div class="post-card__body">
              <span class="post-card__cat">{categoryLabelsVi[post.data.category]}</span>
              <a href={`/blog/${getPostSlug(post.id)}`} class="post-card__title">{post.data.title}</a>
              <p class="post-card__excerpt">{post.data.excerpt}</p>
              <div class="post-card__meta">
                <span>{post.data.readingTime || '5 phút đọc'}</span>
                <span class="post-card__meta-dot" aria-hidden="true"></span>
                <span>{formatDate(post.data.publishedAt)}</span>
              </div>
            </div>
          </div>
        )) : (
          <p style="color:var(--color-fg-3);grid-column:1/-1;padding:2rem 0">
            Chưa có bài viết. <a href="/keystatic">Tạo bài đầu tiên →</a>
          </p>
        )}
